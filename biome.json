{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"plugins": ["./.biome/arrowbodystyle.grit"],
	"files": {
		"includes": ["**"]
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"identifierOrder": "lexicographic",
						"groups": [
							[":NODE:"],
							":BLANK_LINE:",
							[":PACKAGE:"],
							":BLANK_LINE:",
							[":ALIAS:"],
							":BLANK_LINE:",
							[":PATH:"]
						]
					}
				}
			}
		}
	},
	"formatter": {
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"complexity": {
				"useLiteralKeys": "off"
			},
			"style": {
				"noDefaultExport": "on",
				"noNonNullAssertion": "off",
				"useBlockStatements": "on"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.config.*"],
			"linter": {
				"rules": {
					"style": {
						"noDefaultExport": "off"
					}
				}
			}
		}
	]
}
